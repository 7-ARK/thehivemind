APP_ENV=development
MOCK_MODE=true
ALLOW_LIVE_CALLS=false

OPENAI_API_KEY=
OPENAI_TRACKING_ID=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
EXA_API_KEY=
EXA_SERVICE_API_KEY=
EXA_API_KEY_ID=

CEO_MODEL=gpt-5.5
CEO_SERVICE_TIER=flex
CEO_FALLBACK_MODEL=gpt-5.4-nano
CEO_FALLBACK_PROVIDER=openai

MODEL_SELECTOR_MODEL=gemini-3.5-flash
CHEAP_WORKER_MODEL=gpt-5.4-nano
CHEAP_SEARCH_WORKER_MODEL=gemini-3.1-flash-lite
OPENROUTER_DEFAULT_MODEL=qwen/qwen3-coder
ENABLE_REAL_CODING_AGENT=true
ALLOW_REAL_CODING_AGENT=false
REAL_CODING_AGENT_MODEL=moonshotai/kimi-k2.7-code
REAL_CODING_AGENT_FALLBACK_MODEL=qwen/qwen3-coder
REAL_CODING_MAX_INPUT_FILES=12
REAL_CODING_MAX_OUTPUT_FILES=8
REAL_CODING_MAX_OUTPUT_TOKENS=3000
REAL_CODING_MAX_PATCH_BYTES=50000
REAL_CODING_MAX_REPAIR_ATTEMPTS=1
REAL_CODING_REQUIRE_DIFF=true
REAL_CODING_DRY_RUN=false
REAL_CODING_USE_MEMORY=true

DATABASE_URL=sqlite:///./thehivemind.db
VECTOR_STORE_PATH=./data/vector_memory
ARTIFACT_STORE_PATH=./backend/data/artifacts
WORKSPACE_STORE_PATH=./backend/data/workspaces
PROJECT_STORE_PATH=./backend/data/projects
RUN_STORE_PATH=./backend/data/runs
CURRENT_STATE_PATH=./backend/data/current_state.txt
VITE_API_BASE_URL=http://127.0.0.1:8000

MAX_INPUT_TOKENS_PER_CALL=4000
MAX_OUTPUT_TOKENS_PER_CALL=500
MAX_COST_PER_CALL_USD=0.05
MAX_COST_PER_RUN_USD=0.25
MONTHLY_AI_BUDGET_USD=10.00
DAILY_AI_BUDGET_USD=1.00
WARNING_BUDGET_PERCENT=70
DANGER_BUDGET_PERCENT=90

ENABLE_OPENAI_WEB_SEARCH=false
ENABLE_GEMINI_GROUNDING=false
ENABLE_OPENROUTER_SEARCH=false
ENABLE_EXA_SEARCH=false
ENABLE_EXA_OFFICIAL_USAGE_SYNC=false
ALLOW_WEB_SEARCH=false
SEARCH_PROVIDER_DEFAULT=exa_direct

ENABLE_VECTOR_MEMORY=true
MEMORY_TOP_K=5
MEMORY_MAX_TOKENS_PER_AGENT=1200
DEBUG_MEMORY_CONTEXT=false
MEMORY_INGEST_AFTER_RUN=true
MEMORY_USE_IN_MOCK=true
MEMORY_USE_IN_LIVE=false
